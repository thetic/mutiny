---
# C-only clang-tidy config for the mutiny library target.
# Applied only to the library (not tests or examples) via set_target_properties
# in CMakeLists.txt — see the C_CLANG_TIDY property on the mutiny target.
#
# InheritParentConfig: true walks the config FILE's directory hierarchy to
# merge with the project-root .clang-tidy, avoiding duplication.
InheritParentConfig: true
CheckOptions:
  # Linkable extern symbols must carry the mutiny_ prefix.
  - key: readability-identifier-naming.GlobalFunctionCase
    value: lower_case
  - key: readability-identifier-naming.GlobalFunctionPrefix
    value: 'mutiny_'
  # Global variables (all file-scope, including static): require mutiny_ prefix.
  # StaticVariable does not take priority over GlobalVariable in clang-tidy, so
  # there is no way to target extern-only; the rule applies uniformly.
  - key: readability-identifier-naming.GlobalVariableCase
    value: lower_case
  - key: readability-identifier-naming.GlobalVariablePrefix
    value: 'mutiny_'
  # Type tag names (struct/enum/union tags used across TUs) must carry Mutiny.
  - key: readability-identifier-naming.EnumPrefix
    value: 'Mutiny'
  - key: readability-identifier-naming.StructPrefix
    value: 'Mutiny'
  - key: readability-identifier-naming.UnionPrefix
    value: 'Mutiny'
