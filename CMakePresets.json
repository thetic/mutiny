{
  "version": 9,
  "configurePresets": [
    {
      "name": "defaults",
      "binaryDir": "${sourceDir}/build/${presetName}",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "RelWithDebInfo",
        "CMAKE_COMPILE_WARNING_AS_ERROR": true,
        "CMAKE_LINK_WARNING_AS_ERROR": true,
        "CMAKE_CXX_EXTENSIONS": false,
        "CMAKE_C_EXTENSIONS": false,
        "CMAKE_OPTIMIZE_DEPENDENCIES": true,
        "CMAKE_PROJECT_INCLUDE": "${sourceDir}/cfg/warnings.cmake",
        "CMAKE_VERIFY_INTERFACE_HEADER_SETS": true
      },
      "errors": {
        "dev": true
      }
    },
    {
      "name": "shared",
      "inherits": ["defaults"],
      "cacheVariables": {
        "BUILD_SHARED_LIBS": true
      }
    },
    {
      "name": "GNU",
      "inherits": ["defaults"],
      "cacheVariables": {
        "CMAKE_C_COMPILER": "gcc",
        "CMAKE_CXX_COMPILER": "g++"
      }
    },
    {
      "name": "Clang",
      "inherits": ["GNU"],
      "cacheVariables": {
        "CMAKE_C_COMPILER": "clang",
        "CMAKE_CXX_COMPILER": "clang++"
      }
    },
    {
      "name": "clang-tidy",
      "inherits": ["Clang"],
      "cacheVariables": {
        "CMAKE_CXX_CLANG_TIDY": "clang-tidy;-header-filter=.*",
        "CMAKE_C_CLANG_TIDY": "clang-tidy;-header-filter=.*"
      }
    },
    {
      "name": "MSVC",
      "inherits": ["defaults"]
    },
    {
      "name": "ClangCL",
      "inherits": ["MSVC"],
      "generator": "Visual Studio 17 2022",
      "toolset": "ClangCL"
    },
    {
      "name": "MinGW",
      "inherits": ["GNU"],
      "environment": {
        "LDFLAGS": "-static"
      },
      "cacheVariables": {
        "CMAKE_C_COMPILER": "x86_64-w64-mingw32-gcc",
        "CMAKE_CXX_COMPILER": "x86_64-w64-mingw32-g++",
        "CMAKE_SYSTEM_NAME": "Windows",
        "CMAKE_CROSSCOMPILING_EMULATOR": "wine"
      }
    },
    {
      "name": "arm-embedded",
      "inherits": ["defaults"],
      "cacheVariables": {
        "CMAKE_SYSTEM_NAME": "Generic",
        "CMAKE_SYSTEM_PROCESSOR": "cortex-m4",
        "CMAKE_C_COMPILER": "arm-none-eabi-gcc",
        "CMAKE_CXX_COMPILER": "arm-none-eabi-g++",
        "CMAKE_C_FLAGS_INIT": "-mcpu=cortex-m4 -mfpu=fpv4-sp-d16 -mfloat-abi=hard",
        "CMAKE_CXX_FLAGS_INIT": "-mcpu=cortex-m4 -mfpu=fpv4-sp-d16 -mfloat-abi=hard",
        "CMAKE_EXE_LINKER_FLAGS_INIT": "-specs=rdimon.specs",
        "CMAKE_TRY_COMPILE_TARGET_TYPE": "STATIC_LIBRARY",
        "CMAKE_CROSSCOMPILING_EMULATOR": "docker;run;--rm;-v=${sourceDir}:${sourceDir};multiarch/qemu-user-static:arm-7.1.0-2;qemu-arm-static;-cpu;cortex-m4"
      }
    },
    {
      "name": "coverage",
      "inherits": ["GNU"],
      "environment": {
        "CFLAGS": "--coverage",
        "CXXFLAGS": "--coverage"
      },
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Debug",
        "CMAKE_PROJECT_mutiny_INCLUDE": "${sourceDir}/cfg/lcov.cmake",
        "MUTINY_USE_STD_STRING": false,
        "MUTINY_EXAMPLES": false
      }
    },
    {
      "name": "no-std-cpp",
      "inherits": ["GNU"],
      "environment": {
        "CXXFLAGS": "-nostdinc++"
      },
      "cacheVariables": {
        "MUTINY_USE_STD_CPP_LIB": false
      }
    },
    {
      "name": "no-rtti",
      "inherits": ["GNU"],
      "environment": {
        "CXXFLAGS": "-fno-rtti"
      }
    },
    {
      "name": "no-exceptions",
      "inherits": ["GNU"],
      "environment": {
        "CXXFLAGS": "-fno-exceptions"
      }
    },
    {
      "name": "asan",
      "inherits": ["Clang"],
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Debug"
      },
      "environment": {
        "CFLAGS": "-fsanitize=address -fno-omit-frame-pointer",
        "CXXFLAGS": "-fsanitize=address -fno-omit-frame-pointer",
        "LDFLAGS": "-fsanitize=address"
      }
    },
    {
      "name": "msan",
      "inherits": ["Clang"],
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Debug",
        "MUTINY_EXAMPLES": false,
        "MUTINY_USE_STD_CPP_LIB": false
      },
      "environment": {
        "CFLAGS": "-fsanitize=memory -fno-omit-frame-pointer",
        "CXXFLAGS": "-fsanitize=memory -fno-omit-frame-pointer",
        "LDFLAGS": "-fsanitize=memory"
      }
    },
    {
      "name": "ubsan",
      "inherits": ["Clang"],
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Debug",
        "MUTINY_USE_STD_STRING": false
      },
      "environment": {
        "CFLAGS": "-fsanitize=undefined -fno-omit-frame-pointer",
        "CXXFLAGS": "-fsanitize=undefined -fno-omit-frame-pointer",
        "LDFLAGS": "-fsanitize=undefined"
      }
    },
    {
      "name": "detailed",
      "inherits": ["defaults"],
      "cacheVariables": {
        "MUTINY_TESTS_DETAILED": true
      }
    }
  ],
  "buildPresets": [
    {
      "name": "base",
      "hidden": true,
      "jobs": 0,
      "targets": ["all", "all_verify_interface_header_sets"]
    },
    { "name": "defaults",      "inherits": "base", "configurePreset": "defaults" },
    { "name": "shared",        "inherits": "base", "configurePreset": "shared" },
    { "name": "GNU",           "inherits": "base", "configurePreset": "GNU" },
    { "name": "Clang",         "inherits": "base", "configurePreset": "Clang" },
    { "name": "clang-tidy",    "inherits": "base", "configurePreset": "clang-tidy" },
    { "name": "MSVC",          "inherits": "base", "configurePreset": "MSVC",          "configuration": "Debug", "targets": ["ALL_BUILD", "all_verify_interface_header_sets"] },
    { "name": "ClangCL",       "inherits": "base", "configurePreset": "ClangCL",       "configuration": "Debug", "targets": ["ALL_BUILD", "all_verify_interface_header_sets"] },
    { "name": "MinGW",         "inherits": "base", "configurePreset": "MinGW" },
    { "name": "arm-embedded",  "inherits": "base", "configurePreset": "arm-embedded" },
    { "name": "coverage",      "inherits": "base", "configurePreset": "coverage" },
    { "name": "no-std-cpp",    "inherits": "base", "configurePreset": "no-std-cpp" },
    { "name": "no-rtti",       "inherits": "base", "configurePreset": "no-rtti" },
    { "name": "no-exceptions", "inherits": "base", "configurePreset": "no-exceptions" },
    { "name": "asan",          "inherits": "base", "configurePreset": "asan" },
    { "name": "msan",          "inherits": "base", "configurePreset": "msan" },
    { "name": "ubsan",         "inherits": "base", "configurePreset": "ubsan" },
    { "name": "detailed",      "inherits": "base", "configurePreset": "detailed" }
  ],
  "testPresets": [
    {
      "name": "base",
      "hidden": true,
      "execution": {
        "jobs": 0
      },
      "output": {
        "outputOnFailure": true
      }
    },
    { "name": "defaults",      "inherits": "base", "configurePreset": "defaults" },
    { "name": "shared",        "inherits": "base", "configurePreset": "shared" },
    { "name": "GNU",           "inherits": "base", "configurePreset": "GNU" },
    { "name": "Clang",         "inherits": "base", "configurePreset": "Clang" },
    { "name": "clang-tidy",    "inherits": "base", "configurePreset": "clang-tidy" },
    { "name": "MSVC",          "inherits": "base", "configurePreset": "MSVC",          "configuration": "Debug" },
    { "name": "ClangCL",       "inherits": "base", "configurePreset": "ClangCL",       "configuration": "Debug" },
    { "name": "MinGW",         "inherits": "base", "configurePreset": "MinGW" },
    { "name": "arm-embedded",  "inherits": "base", "configurePreset": "arm-embedded" },
    { "name": "coverage",      "inherits": "base", "configurePreset": "coverage" },
    { "name": "no-std-cpp",    "inherits": "base", "configurePreset": "no-std-cpp" },
    { "name": "no-rtti",       "inherits": "base", "configurePreset": "no-rtti" },
    { "name": "no-exceptions", "inherits": "base", "configurePreset": "no-exceptions" },
    { "name": "asan",          "inherits": "base", "configurePreset": "asan" },
    { "name": "msan",          "inherits": "base", "configurePreset": "msan" },
    { "name": "ubsan",         "inherits": "base", "configurePreset": "ubsan" },
    { "name": "detailed",      "inherits": "base", "configurePreset": "detailed" }
  ],
  "packagePresets": [
    {
      "name": "source",
      "configurePreset": "GNU",
      "generators": ["TGZ", "ZIP"],
      "configFile": "${sourceDir}/build/GNU/CPackSourceConfig.cmake"
    }
  ],
  "workflowPresets": [
    {
      "name": "defaults",
      "steps": [
        { "type": "configure", "name": "defaults" },
        { "type": "build",     "name": "defaults" },
        { "type": "test",      "name": "defaults" }
      ]
    },
    {
      "name": "MSVC",
      "steps": [
        { "type": "configure", "name": "MSVC" },
        { "type": "build",     "name": "MSVC" },
        { "type": "test",      "name": "MSVC" }
      ]
    },
    {
      "name": "ClangCL",
      "steps": [
        { "type": "configure", "name": "ClangCL" },
        { "type": "build",     "name": "ClangCL" },
        { "type": "test",      "name": "ClangCL" }
      ]
    },
    {
      "name": "shared",
      "steps": [
        { "type": "configure", "name": "shared" },
        { "type": "build",     "name": "shared" },
        { "type": "test",      "name": "shared" }
      ]
    },
    {
      "name": "GNU",
      "steps": [
        { "type": "configure", "name": "GNU" },
        { "type": "build",     "name": "GNU" },
        { "type": "test",      "name": "GNU" }
      ]
    },
    {
      "name": "Clang",
      "steps": [
        { "type": "configure", "name": "Clang" },
        { "type": "build",     "name": "Clang" },
        { "type": "test",      "name": "Clang" }
      ]
    },
    {
      "name": "clang-tidy",
      "steps": [
        { "type": "configure", "name": "clang-tidy" },
        { "type": "build",     "name": "clang-tidy" }
      ]
    },
    {
      "name": "MinGW",
      "steps": [
        { "type": "configure", "name": "MinGW" },
        { "type": "build",     "name": "MinGW" },
        { "type": "test",      "name": "MinGW" }
      ]
    },
    {
      "name": "arm-embedded",
      "steps": [
        { "type": "configure", "name": "arm-embedded" },
        { "type": "build",     "name": "arm-embedded" },
        { "type": "test",      "name": "arm-embedded" }
      ]
    },
    {
      "name": "coverage",
      "steps": [
        { "type": "configure", "name": "coverage" },
        { "type": "build",     "name": "coverage" },
        { "type": "test",      "name": "coverage" }
      ]
    },
    {
      "name": "no-std-cpp",
      "steps": [
        { "type": "configure", "name": "no-std-cpp" },
        { "type": "build",     "name": "no-std-cpp" },
        { "type": "test",      "name": "no-std-cpp" }
      ]
    },
    {
      "name": "no-rtti",
      "steps": [
        { "type": "configure", "name": "no-rtti" },
        { "type": "build",     "name": "no-rtti" },
        { "type": "test",      "name": "no-rtti" }
      ]
    },
    {
      "name": "no-exceptions",
      "steps": [
        { "type": "configure", "name": "no-exceptions" },
        { "type": "build",     "name": "no-exceptions" },
        { "type": "test",      "name": "no-exceptions" }
      ]
    },
    {
      "name": "asan",
      "steps": [
        { "type": "configure", "name": "asan" },
        { "type": "build",     "name": "asan" },
        { "type": "test",      "name": "asan" }
      ]
    },
    {
      "name": "msan",
      "steps": [
        { "type": "configure", "name": "msan" },
        { "type": "build",     "name": "msan" },
        { "type": "test",      "name": "msan" }
      ]
    },
    {
      "name": "ubsan",
      "steps": [
        { "type": "configure", "name": "ubsan" },
        { "type": "build",     "name": "ubsan" },
        { "type": "test",      "name": "ubsan" }
      ]
    },
    {
      "name": "detailed",
      "steps": [
        { "type": "configure", "name": "detailed" },
        { "type": "build",     "name": "detailed" },
        { "type": "test",      "name": "detailed" }
      ]
    },
    {
      "name": "source-archive",
      "steps": [
        { "type": "configure", "name": "GNU" },
        { "type": "package", "name": "source" }
      ]
    }
  ]
}
