---
BasedOnStyle: Mozilla
AlignAfterOpenBracket: BlockIndent
ContinuationIndentWidth: 4
BreakAfterReturnType: None
AlwaysBreakAfterDefinitionReturnType: None
PenaltyReturnTypeOnItsOwnLine: 10000
Standard: Cpp11
SortIncludes: CaseSensitive
IncludeBlocks: Regroup
IncludeCategories:
  # 1. Local includes (quoted, no path separator — the "no-slash" anchor is critical)
  - Regex:           '^"[^/"]*"$'
    Priority:        1
    SortPriority:    1
  # 2. mu::tiny mock includes
  - Regex:           '^"mu/tiny/mock/'
    Priority:        2
    SortPriority:    2
  # 3. mu::tiny test includes
  - Regex:           '^"mu/tiny/test/'
    Priority:        3
    SortPriority:    3
  # 4. mu::tiny core includes
  - Regex:           '^"mu/tiny/'
    Priority:        4
    SortPriority:    4
  # 5. System/POSIX headers (angle-bracket with subdirectory path)
  - Regex:           '^<[^>]*/[^>]*>'
    Priority:        5
    SortPriority:    5
  # 6. C++ standard headers (angle-bracket, no .h extension)
  - Regex:           '^<[a-zA-Z][^.>]*>'
    Priority:        6
    SortPriority:    6
  # 7. C standard headers (angle-bracket with .h)
  - Regex:           '^<[^>]+\.h>'
    Priority:        7
    SortPriority:    7
Macros:
  - TEST_GROUP(x)=class x
  - TEST(x,y)=void x()
  - TEST_GROUP_C_WRAPPER(x)=class x
FixNamespaceComments: true
