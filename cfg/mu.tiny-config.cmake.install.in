@PACKAGE_INIT@

set_and_check(mu.tiny_INCLUDE_DIRS "@PACKAGE_INCLUDE_INSTALL_DIR@")
set(MUTINY_MODULE_PATH "${CMAKE_CURRENT_LIST_DIR}/Modules")
list(APPEND CMAKE_MODULE_PATH "${MUTINY_MODULE_PATH}")
include("${CMAKE_CURRENT_LIST_DIR}/mu.tiny-Targets.cmake")

set(mu.tiny_LIBRARIES mu::tiny)

check_required_components(mu.tiny)
