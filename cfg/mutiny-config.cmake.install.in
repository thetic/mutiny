@PACKAGE_INIT@

set_and_check(mutiny_INCLUDE_DIRS "@PACKAGE_INCLUDE_INSTALL_DIR@")
set(MUTINY_MODULE_PATH "${CMAKE_CURRENT_LIST_DIR}/Modules")
list(APPEND CMAKE_MODULE_PATH "${MUTINY_MODULE_PATH}")
include("${CMAKE_CURRENT_LIST_DIR}/mutinyTargets.cmake")

set(mutiny_LIBRARIES mu::tiny)

check_required_components(mutiny)
