@PACKAGE_INIT@

set_and_check(CppUTest_INCLUDE_DIRS "@PACKAGE_INCLUDE_DIR@")
if(NOT TARGET CppUTest)
  include("${CMAKE_CURRENT_LIST_DIR}/CppUTestTargets.cmake")
endif()

if(TARGET CppUTest::Extensions)
    set(CppUTest_Extensions_FOUND TRUE)
endif()

set(CppUTest_LIBRARIES CppUTest::CppUTest)
if(CppUTest_Extensions_FOUND)
    list(APPEND CppUTest_LIBRARIES CppUTest::Extensions)
endif()

check_required_components(CppUTest)
